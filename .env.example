# Azure Blob Storage configuration
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_BLOB_CONTAINER=
# Optional: AZURE_BLOB_ENDPOINT=https://<account>.blob.core.windows.net
# Database Configuration
DB_01_SERVER=localhost
DB_01_NAME=master
DB_01_USER=sa
DB_01_PASSWORD=YourStrong!Password
DB_01_DRIVER=ODBC Driver 18 for SQL Server
DB_01_PORT=1433

# Startup-owned transport settings (used by run_server_entrypoint)
# MCP_TRANSPORT=http
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# Optional server metadata for FastMCP constructor
# MCP_SERVER_INSTRUCTIONS=Read-only SQL assistant
# MCP_SERVER_VERSION=1.0.0

# Optional HTTP auth settings (startup-owned for HTTP transport)
# Supported FASTMCP_AUTH_TYPE values:
#   none, apikey, oidc, jwt, azure-ad, github, google
# FASTMCP_AUTH_TYPE=none
# FASTMCP_API_KEY=replace-with-long-random-token
# MCP_ALLOW_QUERY_TOKEN_AUTH=false
# Precedence notes:
# - If FASTMCP_AUTH_TYPE is empty/none, auth is disabled and query-token auth is ignored.
# - If FASTMCP_AUTH_TYPE=apikey, FASTMCP_API_KEY is required for HTTP startup.

# Optional: SSH Tunnel Configuration
# SSH_HOST=bastion.example.com
# SSH_PORT=22
# SSH_USER=ec2-user
# SSH_PASSWORD=secret
# SSH_KEY_PATH=/path/to/private/key

# Optional: Table scope hardening (least privilege at MCP layer)
# MCP_TABLE_SCOPE_ENFORCED=true
# MCP_ALLOWED_TABLES=dbo.Customers,dbo.Orders,reporting.*

# Optional: HTTP rate limiting and circuit breaker
# MCP_RATE_LIMIT_ENABLED=true
# MCP_RATE_LIMIT_WINDOW_SECONDS=60
# MCP_RATE_LIMIT_MAX_REQUESTS=240
# MCP_RATE_LIMIT_BREAKER_VIOLATIONS=3
# MCP_RATE_LIMIT_BREAKER_SECONDS=60

# Optional: Query audit logging (JSONL)
# MCP_AUDIT_LOG_QUERIES=true
# MCP_AUDIT_LOG_FILE=mcp_query_audit.jsonl
# MCP_AUDIT_LOG_INCLUDE_PARAMS=false
# MCP_ALLOW_RAW_PROMPTS=false

# Optional: FastMCP background task backend (default memory://)
# FASTMCP_DOCKET_URL=memory://
# FASTMCP_DOCKET_URL=redis://redis:6379/0
# FASTMCP_DOCKET_CONCURRENCY=10

# Optional: FastMCP component list pagination (tools/resources/prompts)
# MCP_LIST_PAGE_SIZE=50

# Optional: FastMCP tool-search transform (requires fastmcp>=3.1.0)
# MCP_TOOL_SEARCH_ENABLED=false
# Safe defaults: keep disabled unless you need search aggregation in the tool catalog.
# MCP_TOOL_SEARCH_STRATEGY=regex
# Allowed values: regex or bm25
# MCP_TOOL_SEARCH_MAX_RESULTS=5
# Optional positive integer; ignored when unset.
# MCP_TOOL_SEARCH_ALWAYS_VISIBLE=db_sql2019_ping,db_sql2019_server_info_mcp
# Comma-separated tool names kept visible in search results.
# MCP_TOOL_SEARCH_TOOL_NAME=search_tools
# MCP_TOOL_CALL_TOOL_NAME=call_tool

# Optional: Provider-layer transform suite (default-safe; all feature flags disabled)
# MCP_TRANSFORM_LAYERS_ENABLED=true
# MCP_TRANSFORM_LAYER_ORDER=visibility,namespace,tool_transformation,resources_as_tools,prompts_as_tools,code_mode
#
# Visibility transform
# MCP_TRANSFORM_VISIBILITY_ENABLED=false
# MCP_TRANSFORM_VISIBILITY_ALLOWLIST=db_01_ping,db_01_list_databases
# MCP_TRANSFORM_VISIBILITY_DENYLIST=db_01_drop_object,db_02_drop_object
#
# Namespace transform
# MCP_TRANSFORM_NAMESPACE_ENABLED=false
# MCP_TRANSFORM_NAMESPACE_PREFIX=sql
#
# ToolTransformation transform (JSON object maps)
# MCP_TRANSFORM_TOOL_TRANSFORMATION_ENABLED=false
# MCP_TRANSFORM_TOOL_NAME_MAP={"db_01_ping":"sql_ping"}
# MCP_TRANSFORM_TOOL_DESCRIPTION_MAP={"db_01_ping":"Connectivity probe for primary SQL instance"}
#
# ResourcesAsTools / PromptsAsTools transforms
# MCP_TRANSFORM_RESOURCES_AS_TOOLS_ENABLED=false
# MCP_TRANSFORM_PROMPTS_AS_TOOLS_ENABLED=false
#
# CodeMode transform
# MCP_TRANSFORM_CODE_MODE_ENABLED=false
# MCP_TRANSFORM_CODE_MODE_POLICY=safe


# Instance 2
DB_02_SERVER=
DB_02_PORT=1433
DB_02_USER=
DB_02_PASSWORD=
DB_02_NAME=master
DB_02_DRIVER=ODBC Driver 17 for SQL Server
DB_02_ENCRYPT=no
DB_02_TRUST_CERT=yes
