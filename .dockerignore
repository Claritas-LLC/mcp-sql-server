# Exclude everything by default; explicitly include only files required
# to build and run the MCP SQL Server container image.
**

# Build/runtime entrypoints
!requirements.txt
!server_startup.py
!server.py

# Application package
!mcp_sqlserver/
!mcp_sqlserver/**

# Exclude local-only artifacts inside the package
mcp_sqlserver/test_server.py
mcp_sqlserver/__pycache__/
